{
  "name": "habbit",
  "productName": "Habbit",
  "version": "1.0.0",
  "description": "A simple app to track your habits!",
  "main": "src/app.js",
  "scripts": {
    "start": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron-forge start",
    "build:renderer": "vite build",
    "package": "npm run build:renderer && electron-forge package",
    "make": "npm run build:renderer && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-deb": "7.11.2",
    "@electron-forge/maker-rpm": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron/fuses": "2.1.1",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.0",
    "cross-env": "10.1.0",
    "electron": "42.3.0",
    "vite": "8.0.14",
    "wait-on": "9.0.10"
  },
  "keywords": [],
  "author": "Yaroslav Petrov <PersonalYP00@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "1.0.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "build": {
    "appId": "com.no1.cares.tbh"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
