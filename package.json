{
  "name": "habbit",
  "productName": "Habbit",
  "version": "1.0.0",
  "description": "A simple app to track your habits!",
  "main": "src/app.js",
  "scripts": {
    "start": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron-forge start",
    "build:renderer": "vite build",
    "package": "npm run build:renderer && electron-forge package",
    "make": "npm run build:renderer && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^31.2.0",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "keywords": [],
  "author": "Yaroslav Petrov <PersonalYP00@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "build": {
    "appId": "com.no1.cares.tbh"
  }
}
